{
  "name": "@mpv-easy/easy-react-tpl",
  "version": "0.1.15-alpha.20",
  "homepage": "https://github.com/mpv-easy/mpv-easy#readme",
  "files": [
    "dist",
    "readme.md",
    "package.json"
  ],
  "engines": {
    "node": "20"
  },
  "description": "mpv-easy-tpl",
  "main": "./dist/index.js",
  "scripts": {
    "bundle": "tsx scripts/build.ts",
    "es5": "babel --presets  @babel/preset-env ./bundle -d es5",
    "dev": "chokidar '../mpv-*/src/**/*' -c 'pnpm run build' -d 2000 --initial",
    "build": "pnpm run bundle && pnpm run es5",
    "build:osc": "pnpm run build && tsx scripts/build-osc.ts",
    "copy": "cp es5/mpv-easy-tpl.js $MPV_CONFIG_DIR",
    "download": "tsx scripts/download.ts"
  },
  "keywords": [],
  "author": "ahaoboy <504595380@qq.com> (https://github.com/ahaoboy)",
  "license": "MIT",
  "dependencies": {
    "@easy-install/easy-archive": "0.2.6",
    "@mpv-easy/polyfill": "workspace:*",
    "@mpv-easy/react": "workspace:*",
    "@mpv-easy/tool": "workspace:*",
    "react": "19.2.6"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-typescript": "7.28.5",
    "chokidar-cli": "3.0.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.28.0",
    "tsx": "4.22.3"
  }
}
